# Copy this file to .env and adjust values before deployment.

TZ=Asia/Shanghai

# Persistent data root on the Docker host.
MONITORING_DATA_DIR=/data/monitoring

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# DingTalk robot webhook, for example:
# https://oapi.dingtalk.com/robot/send?access_token=xxxx
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# Lark/Feishu robot webhook, for example:
# https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
LARK_WEBHOOK_URL=
LARK_SECRET=

# Optional text prefix shown in notification title.
ALERT_TITLE_PREFIX=监控告警
